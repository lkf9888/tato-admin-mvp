generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum VehicleStatus {
  available
  maintenance
  inactive
}

enum OwnerAccessType {
  share_link
  account_login
}

enum OrderSource {
  turo
  offline
}

enum OrderStatus {
  booked
  ongoing
  completed
  cancelled
}

enum ShareVisibility {
  standard
  privacy
}

enum WorkspaceBillingStatus {
  inactive
  incomplete
  incomplete_expired
  trialing
  active
  past_due
  canceled
  unpaid
  paused
}

enum OwnerLedgerKind {
  OWNER_NET_EARNING
  MANAGER_COMMISSION
  EXPENSE_REIMBURSEMENT
  MANUAL_ADJUSTMENT
  SETTLEMENT_PAYMENT
}

enum OrderAttachmentKind {
  photo
  document
}

model Workspace {
  id               String            @id @default(cuid())
  name             String
  slug             String            @unique
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  users            User[]
  owners           Owner[]
  vehicles         Vehicle[]
  orders           Order[]
  importBatches    ImportBatch[]
  shareLinks       ShareLink[]
  activityLogs     ActivityLog[]
  ownerLedgerItems OwnerLedgerItem[]
  orderAttachments OrderAttachment[]
  billing          WorkspaceBilling?
}

model User {
  id              String     @id @default(cuid())
  workspaceId     String?
  name            String
  email           String     @unique
  passwordHash    String
  isBillingExempt Boolean    @default(false)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  workspace       Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
}

model Owner {
  workspaceId String?
  id          String            @id @default(cuid())
  name        String
  phone       String?
  email       String?
  companyName String?
  accessType  OwnerAccessType   @default(share_link)
  notes       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  workspace   Workspace?        @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  vehicles    Vehicle[]
  shareLinks  ShareLink[]
  ledgerItems OwnerLedgerItem[]

  @@index([workspaceId])
}

model Vehicle {
  workspaceId          String?
  id                   String            @id @default(cuid())
  ownerId              String?
  plateNumber          String            @unique
  nickname             String
  brand                String
  model                String
  year                 Int
  vin                  String?
  status               VehicleStatus     @default(available)
  turoListingName      String?
  turoVehicleCode      String?
  purchasePrice        Float?
  ownerCommissionRate  Float?
  directBookingEnabled Boolean           @default(false)
  bookingDailyRate     Float?
  bookingInsuranceFee  Float?
  bookingDepositAmount Float?
  bookingIntro         String?
  notes                String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  workspace            Workspace?        @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  owner                Owner?            @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  orders               Order[]
  ownerLedgerItems     OwnerLedgerItem[]

  @@index([workspaceId])
}

model Order {
  workspaceId      String?
  id               String            @id @default(cuid())
  vehicleId        String
  importBatchId    String?
  source           OrderSource
  externalOrderId  String?
  renterName       String
  renterPhone      String?
  pickupDatetime   DateTime
  returnDatetime   DateTime
  totalPrice       Float?
  depositAmount    Float?
  status           OrderStatus       @default(booked)
  pickupLocation   String?
  returnLocation   String?
  paymentMethod    String?
  contractNumber   String?
  notes            String?
  sourceMetadata   String?
  createdBy        String
  isArchived       Boolean           @default(false)
  hasConflict      Boolean           @default(false)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  workspace        Workspace?        @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  importBatch      ImportBatch?      @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  vehicle          Vehicle           @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  ownerLedgerItems OwnerLedgerItem[]
  attachments      OrderAttachment[]

  @@index([workspaceId])
  @@index([workspaceId, isArchived])
  @@index([vehicleId, pickupDatetime, returnDatetime])
  @@index([source, externalOrderId])
}

model ImportBatch {
  workspaceId String?
  id          String     @id @default(cuid())
  fileName    String
  importedBy  String
  importedAt  DateTime   @default(now())
  totalRows   Int
  successRows Int
  failedRows  Int
  notes       String?
  mapping     String?
  failures    String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  orders      Order[]

  @@index([workspaceId])
}

model OwnerLedgerItem {
  workspaceId String?
  id          String          @id @default(cuid())
  ownerId     String
  vehicleId   String?
  orderId     String?
  kind        OwnerLedgerKind
  amount      Float
  occurredAt  DateTime
  note        String?
  isAuto      Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  workspace   Workspace?      @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  owner       Owner           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  vehicle     Vehicle?        @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  order       Order?          @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([ownerId, occurredAt])
  @@index([vehicleId, occurredAt])
  @@index([orderId])
}

model OrderAttachment {
  workspaceId String?
  id          String              @id @default(cuid())
  orderId     String?
  kind        OrderAttachmentKind
  url         String?
  pathname    String
  filename    String?
  contentType String?
  size        Int?
  isArchived  Boolean             @default(false)
  uploadedAt  DateTime            @default(now())
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  workspace   Workspace?          @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  order       Order?              @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([orderId, kind])
  @@index([isArchived])
  @@index([uploadedAt])
}

model ShareLink {
  workspaceId  String?
  id           String          @id @default(cuid())
  ownerId      String
  token        String          @unique
  passwordHash String?
  expiresAt    DateTime?
  isActive     Boolean         @default(true)
  visibility   ShareVisibility @default(standard)
  createdBy    String
  createdAt    DateTime        @default(now())
  workspace    Workspace?      @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  owner        Owner           @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model WorkspaceBilling {
  id                            String                    @id @default(cuid())
  workspaceId                   String?                   @unique
  freeVehicleSlots              Int                       @default(5)
  bonusVehicleSlots             Int                       @default(0)
  purchasedVehicleSlots         Int                       @default(0)
  stripeCustomerId              String?                   @unique
  stripeSubscriptionId          String?                   @unique
  stripeSubscriptionItemId      String?
  stripePriceId                 String?
  stripePortalConfigurationId   String?
  stripeLatestCheckoutSessionId String?
  status                        WorkspaceBillingStatus    @default(inactive)
  currentPeriodStart            DateTime?
  currentPeriodEnd              DateTime?
  lastCheckoutAt                DateTime?
  lastPaidAt                    DateTime?
  // Stripe Connect fields — per-workspace payout account for direct-booking
  // revenue. The platform (site owner) collects a flat application fee and the
  // rest is settled on-behalf-of the host's Connect account, so renters see
  // the host's business name on their statement.
  stripeConnectAccountId        String?                   @unique
  stripeConnectCountry          String?
  stripeConnectChargesEnabled   Boolean                   @default(false)
  stripeConnectPayoutsEnabled   Boolean                   @default(false)
  stripeConnectDetailsSubmitted Boolean                   @default(false)
  stripeConnectOnboardedAt      DateTime?
  createdAt                     DateTime                  @default(now())
  updatedAt                     DateTime                  @updatedAt
  workspace                     Workspace?                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  couponRedemptions             BillingCouponRedemption[]
}

model BillingCouponRedemption {
  id                 String           @id @default(cuid())
  workspaceBillingId String
  code               String           @unique
  couponType         String
  bonusVehicleSlots  Int              @default(0)
  metadata           String?
  createdAt          DateTime         @default(now())
  workspaceBilling   WorkspaceBilling @relation(fields: [workspaceBillingId], references: [id], onDelete: Cascade)

  @@index([workspaceBillingId])
}

model EmailVerification {
  id         String    @id @default(cuid())
  email      String
  codeHash   String
  purpose    String    @default("registration")
  expiresAt  DateTime
  attempts   Int       @default(0)
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([email, purpose])
  @@index([expiresAt])
}

model ActivityLog {
  workspaceId String?
  id          String     @id @default(cuid())
  actor       String
  action      String
  entityType  String
  entityId    String
  metadata    String?
  createdAt   DateTime   @default(now())
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
}

// Sliding-window rate limit for sensitive auth surfaces (login,
// share-link unlock). One row per (scope, identifier). Old rows are
// best-effort GC'd inside `lib/rate-limit.ts` when checked. The model
// is intentionally generic so the same primitive covers any future
// throttled flow (e.g. password-reset request).
model RateLimitAttempt {
  id            String   @id @default(cuid())
  // Stable bucket name, e.g. "login_email" / "login_ip" / "share_unlock".
  scope         String
  // Bucket key within the scope, e.g. lowercased email, share token,
  // or client IP. Combined with scope it forms a unique row.
  identifier    String
  // Number of failed attempts within the current window. Resets to 0
  // by deleting the row once the window expires.
  attempts      Int      @default(0)
  // Start of the active window. New row → now(); refreshed when a row
  // ages past its window before the next failure is recorded.
  windowStart   DateTime @default(now())
  // Wall clock of the most recent failure, useful for alerting.
  lastAttemptAt DateTime @default(now())

  @@unique([scope, identifier])
  @@index([windowStart])
}
