generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum VehicleStatus {
  available
  maintenance
  inactive
}

enum OwnerAccessType {
  share_link
  account_login
}

enum OrderSource {
  turo
  offline
}

enum OrderStatus {
  booked
  ongoing
  completed
  cancelled
}

enum ShareVisibility {
  standard
  privacy
}

enum WorkspaceBillingStatus {
  inactive
  incomplete
  incomplete_expired
  trialing
  active
  past_due
  canceled
  unpaid
  paused
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Owner {
  id          String          @id @default(cuid())
  name        String
  phone       String?
  email       String?
  companyName String?
  accessType  OwnerAccessType @default(share_link)
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  vehicles    Vehicle[]
  shareLinks  ShareLink[]
}

model Vehicle {
  id              String        @id @default(cuid())
  ownerId         String?
  plateNumber     String        @unique
  nickname        String
  brand           String
  model           String
  year            Int
  vin             String?
  status          VehicleStatus @default(available)
  turoListingName String?
  turoVehicleCode String?
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  owner           Owner?        @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  orders          Order[]
}

model Order {
  id              String       @id @default(cuid())
  vehicleId       String
  importBatchId   String?
  source          OrderSource
  externalOrderId String?
  renterName      String
  renterPhone     String?
  pickupDatetime  DateTime
  returnDatetime  DateTime
  totalPrice      Float?
  depositAmount   Float?
  status          OrderStatus  @default(booked)
  pickupLocation  String?
  returnLocation  String?
  paymentMethod   String?
  contractNumber  String?
  notes           String?
  sourceMetadata  String?
  createdBy       String
  hasConflict     Boolean      @default(false)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  importBatch     ImportBatch? @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  vehicle         Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId, pickupDatetime, returnDatetime])
  @@index([source, externalOrderId])
}

model ImportBatch {
  id          String   @id @default(cuid())
  fileName    String
  importedBy  String
  importedAt  DateTime @default(now())
  totalRows   Int
  successRows Int
  failedRows  Int
  notes       String?
  mapping     String?
  failures    String?
  orders      Order[]
}

model ShareLink {
  id           String          @id @default(cuid())
  ownerId      String
  token        String          @unique
  passwordHash String?
  expiresAt    DateTime?
  isActive     Boolean         @default(true)
  visibility   ShareVisibility @default(standard)
  createdBy    String
  createdAt    DateTime        @default(now())
  owner        Owner           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
}

model WorkspaceBilling {
  id                           String                 @id
  freeVehicleSlots             Int                    @default(5)
  purchasedVehicleSlots        Int                    @default(0)
  stripeCustomerId             String?                @unique
  stripeSubscriptionId         String?                @unique
  stripeSubscriptionItemId     String?
  stripePriceId                String?
  stripePortalConfigurationId  String?
  stripeLatestCheckoutSessionId String?
  status                       WorkspaceBillingStatus @default(inactive)
  currentPeriodStart           DateTime?
  currentPeriodEnd             DateTime?
  lastCheckoutAt               DateTime?
  lastPaidAt                   DateTime?
  createdAt                    DateTime               @default(now())
  updatedAt                    DateTime               @updatedAt
}

model ActivityLog {
  id         String   @id @default(cuid())
  actor      String
  action     String
  entityType String
  entityId   String
  metadata   String?
  createdAt  DateTime @default(now())
}
