generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum VehicleStatus {
  available
  maintenance
  inactive
}

enum OwnerAccessType {
  share_link
  account_login
}

enum OrderSource {
  turo
  offline
}

enum OrderStatus {
  booked
  ongoing
  completed
  cancelled
}

enum ShareVisibility {
  standard
  privacy
}

enum WorkspaceBillingStatus {
  inactive
  incomplete
  incomplete_expired
  trialing
  active
  past_due
  canceled
  unpaid
  paused
}

model Workspace {
  id            String            @id @default(cuid())
  name          String
  slug          String            @unique
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  users         User[]
  owners        Owner[]
  vehicles      Vehicle[]
  orders        Order[]
  importBatches ImportBatch[]
  shareLinks    ShareLink[]
  activityLogs  ActivityLog[]
  billing       WorkspaceBilling?
}

model User {
  id              String    @id @default(cuid())
  workspaceId     String?
  name            String
  email           String    @unique
  passwordHash    String
  isBillingExempt Boolean @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  workspace       Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
}

model Owner {
  workspaceId  String?
  id          String          @id @default(cuid())
  name        String
  phone       String?
  email       String?
  companyName String?
  accessType  OwnerAccessType @default(share_link)
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  workspace   Workspace?      @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  vehicles    Vehicle[]
  shareLinks  ShareLink[]

  @@index([workspaceId])
}

model Vehicle {
  workspaceId      String?
  id              String        @id @default(cuid())
  ownerId         String?
  plateNumber     String
  nickname        String
  brand           String
  model           String
  year            Int
  vin             String?
  status          VehicleStatus @default(available)
  turoListingName String?
  turoVehicleCode String?
  purchasePrice   Float?
  directBookingEnabled Boolean   @default(false)
  bookingDailyRate     Float?
  bookingInsuranceFee  Float?
  bookingDepositAmount Float?
  bookingIntro         String?
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  workspace       Workspace?    @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  owner           Owner?        @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  orders          Order[]

  @@unique([workspaceId, plateNumber])
  @@index([workspaceId])
}

model Order {
  workspaceId      String?
  id              String       @id @default(cuid())
  vehicleId       String
  importBatchId   String?
  source          OrderSource
  externalOrderId String?
  renterName      String
  renterPhone     String?
  pickupDatetime  DateTime
  returnDatetime  DateTime
  totalPrice      Float?
  depositAmount   Float?
  status          OrderStatus  @default(booked)
  pickupLocation  String?
  returnLocation  String?
  paymentMethod   String?
  contractNumber  String?
  notes           String?
  sourceMetadata  String?
  createdBy       String
  hasConflict     Boolean      @default(false)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  workspace       Workspace?   @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  importBatch     ImportBatch? @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  vehicle         Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([vehicleId, pickupDatetime, returnDatetime])
  @@index([source, externalOrderId])
}

model ImportBatch {
  workspaceId String?
  id          String   @id @default(cuid())
  fileName    String
  importedBy  String
  importedAt  DateTime @default(now())
  totalRows   Int
  successRows Int
  failedRows  Int
  notes       String?
  mapping     String?
  failures    String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  orders      Order[]

  @@index([workspaceId])
}

model ShareLink {
  workspaceId   String?
  id           String          @id @default(cuid())
  ownerId      String
  token        String          @unique
  passwordHash String?
  expiresAt    DateTime?
  isActive     Boolean         @default(true)
  visibility   ShareVisibility @default(standard)
  createdBy    String
  createdAt    DateTime        @default(now())
  workspace    Workspace?      @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  owner        Owner           @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model WorkspaceBilling {
  id                           String                 @id @default(cuid())
  workspaceId                  String                 @unique
  freeVehicleSlots             Int                    @default(5)
  bonusVehicleSlots            Int                    @default(0)
  purchasedVehicleSlots        Int                    @default(0)
  stripeCustomerId             String?                @unique
  stripeSubscriptionId         String?                @unique
  stripeSubscriptionItemId     String?
  stripePriceId                String?
  stripePortalConfigurationId  String?
  stripeLatestCheckoutSessionId String?
  status                       WorkspaceBillingStatus @default(inactive)
  currentPeriodStart           DateTime?
  currentPeriodEnd             DateTime?
  lastCheckoutAt               DateTime?
  lastPaidAt                   DateTime?
  createdAt                    DateTime               @default(now())
  updatedAt                    DateTime               @updatedAt
  workspace                    Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  couponRedemptions            BillingCouponRedemption[]
}

model BillingCouponRedemption {
  id                String           @id @default(cuid())
  workspaceBillingId String
  code              String           @unique
  couponType        String
  bonusVehicleSlots Int              @default(0)
  metadata          String?
  createdAt         DateTime         @default(now())
  workspaceBilling  WorkspaceBilling @relation(fields: [workspaceBillingId], references: [id], onDelete: Cascade)

  @@index([workspaceBillingId])
}

model ActivityLog {
  workspaceId String?
  id         String   @id @default(cuid())
  actor      String
  action     String
  entityType String
  entityId   String
  metadata   String?
  createdAt  DateTime @default(now())
  workspace  Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
}
